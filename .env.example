# ============================================================
# 全球華人新聞網 (GCN) — 環境變數完整清單
# 複製此檔案為 .env.local（本機開發）或在 Vercel Dashboard 設定（生產）
# ============================================================
# 標記說明：
#   [必填]   — 未設定將導致功能異常
#   [建議]   — 無值時使用內建 fallback，但建議設定
#   [可選]   — 僅在啟用對應功能時才需設定
#   [Crawler] — 僅自動抓取功能需要
# ============================================================




# ════════════════════════════════════════════════════════════
# 區塊 1：站點基本資訊
# ════════════════════════════════════════════════════════════

# [必填] 前端網站的公開 URL（結尾不加 /）
NEXT_PUBLIC_SITE_URL=https://mynews.com

# [建議] 網站名稱，用於 <title> 和 Open Graph
NEXT_PUBLIC_SITE_NAME=全球華人新聞網

# [建議] 網站預設語言（HTML lang 屬性）
NEXT_PUBLIC_SITE_LOCALE=zh-Hant



# ════════════════════════════════════════════════════════════
# 區塊 2：WordPress Headless CMS 連接
# ════════════════════════════════════════════════════════════

# [必填] WordPress 站點 URL（不含 /graphql）
NEXT_PUBLIC_WP_URL=https://cms.mynews.com

# [必填] WordPress 主機名（用於 next.config.js 的 images.remotePatterns）
WORDPRESS_HOSTNAME=cms.mynews.com



# ════════════════════════════════════════════════════════════
# 區塊 3：ISR 緩存重新驗證
# ════════════════════════════════════════════════════════════

# [必填] 保護 /api/revalidate 的秘密金鑰（隨機字串，建議 32+ 字符）
REVALIDATE_SECRET_KEY=generate-a-random-string-at-least-32-chars



# ════════════════════════════════════════════════════════════
# 區塊 4：Cron 安全
# ════════════════════════════════════════════════════════════

# [Crawler] [必填] 手動觸發 /api/crawler?secret=xxx 時使用的驗證金鑰
CRON_SECRET=generate-another-random-string-32-chars



# ════════════════════════════════════════════════════════════
# 區塊 5：WordPress REST API 認證（自動抓取發布用）
# ════════════════════════════════════════════════════════════

# [Crawler] [必填] WordPress 使用者名稱（建議建立專用的 editor 帳號）
WP_USERNAME=crawler-bot

# [Crawler] [必填] WordPress Application Password
# 生成路徑：WP 後台 → 使用者 → 編輯該帳號 → 滑到最底 → Application Passwords
# 格式範例：abcd EFGH 1234 ijkl MNOP 5678
WP_APPLICATION_PASSWORD=abcd EFGH 1234 ijkl MNOP 5678

# [Crawler] [必填] 抓取文章預設歸入的 WordPress 分類 ID
DEFAULT_CATEGORY_ID=3



# ════════════════════════════════════════════════════════════
# 區塊 6：自動抓取 — RSS 源與黑名單
# ════════════════════════════════════════════════════════════

# [Crawler] [必填] RSS 來源列表（逗號分隔，無空格）
# 注意：建議控制在 5–8 個以內，以免逾時
CRAWLER_RSS_FEEDS=https://feeds.bbc.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://www.theguardian.com/world/rss,https://feeds.dw.com/rss/rss-en-all,https://www.france24.com/en/rss

# [Crawler] [建議] 黑名單域名（這些域名的文章直接跳過）
BLACKLIST_DOMAINS=reuters.com,bloomberg.com,caixin.com,wsj.com,ft.com,economist.com

# [Crawler] [建議] 黑名單關鍵詞（標題或正文包含任一詞則跳過）
BLACKLIST_KEYWORDS=獨家,嚴禁轉載,付費內容,會員專享,訂閱解鎖,版權所有,未經許可禁止轉載



# ════════════════════════════════════════════════════════════
# 區塊 7：Upstash Redis（去重存儲）
# ════════════════════════════════════════════════════════════

# [Crawler] [建議] Upstash Redis REST URL
# 建立免費 Redis：https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://us1-fresh-mastodon-12345.upstash.io

# [Crawler] [建議] Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here



# ════════════════════════════════════════════════════════════
# 區塊 8：第三方服務（可選）
# ════════════════════════════════════════════════════════════

# [可選] Google Analytics 4 測量 ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# [可選] Google Search Console 驗證碼
# NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx



# ════════════════════════════════════════════════════════════
# 區塊 9：Resend 郵件告警（Crawler 失敗通知）
# ════════════════════════════════════════════════════════════

# [Crawler] [建議] Resend API Key（https://resend.com → API Keys）
RESEND_API_KEY=re_xxxxxxxxxxxx

# [Crawler] [建議] 告警郵件寄件人（需在 Resend 中驗證域名）
ALERT_EMAIL_FROM=alert@mynews.com

# [Crawler] [建議] 告警郵件收件人
ALERT_EMAIL_TO=admin@mynews.com
