add('105','FileZilla','filezilla','3.68','12 MB',['windows','mac','linux'],'network','Free FTP/SFTP/FTPS client. Reliable file transfers with intuitive interface.','FileZilla supports FTP, FTPS, and SFTP protocols. Features tabbed interface, directory comparison, remote file editing, filename filters, and transfer queue. Available as client and server.','📁','https://download.filezilla-project.org/client/FileZilla_3.68.0_win64-setup.exe','https://filezilla-project.org','Free (GPL)',['English','中文'],'2026-06-10',1800000,4.5,['FTP','transfer','open-source']);
