export interface Software {
  id: string; name: string; slug: string; version: string; size: string;
  platform: string[]; category: string; description: string; longDescription: string;
  icon: string; downloadUrl: string; officialSite: string; license: string;
  language: string[]; updateDate: string; downloads: number; rating: number; tags: string[];
}

const S: Software[] = [];

function add(id:string,n:string,slug:string,ver:string,size:string,plat:string[],cat:string,desc:string,long:string,icon:string,url:string,site:string,lic:string,lang:string[],date:string,dl:number,rt:number,tags:string[]){
